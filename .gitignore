# --- Binaries and Executables ---
# Compiled binaires (standard naming)
*.exe
*.exe~
*.dll
*.so
*.dylib

# Specific Go tool outputs
bin/
obj/

# --- Dependency Management ---
# Most people don't commit 'vendor' unless specifically required
# vendor/

# --- Testing and Coverage ---
*.test
*.out
coverage.txt

# --- IDE and Editor Specifics ---
# JetBrains (GoLand)
.idea/
*.iml

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Vim/Emacs
*~
*.swp
.DS_Store

# --- Environment and Secrets ---
# Crucial for security (prevents local secrets from leaking)
.env
.env.local
.env.*.local

# --- OS Specific ---
dist/
build/
